<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h2 class="card-title text-warning mb-3">
                Singleton Service
            </h2>

            <p>
                <strong>Service Instance 1:</strong>
                <span class="text-success">@ViewBag.Id1</span>
            </p>

            <p>
                <strong>Service Instance 2:</strong>
                <span class="text-success">@ViewBag.Id2</span>
            </p>

            <div class="alert alert-warning mt-3" role="alert">
                <strong>Note:</strong> Singleton services are created only once and shared throughout the application's lifetime. Therefore, the two instances above will have the same ID.
            </div>
        </div>
    </div>
</div>